{
  "name": "scaffold-vscode",
  "displayName": "Scaffold: Structured Planning for AI Coding",
  "description": "Scaffold is a local-first VS Code extension for workspace-scoped planning with gated docs, approvals, and AI-ready code prompts.",
  "version": "0.0.2",
  "publisher": "prasadkirpekar",
  "author": {
    "name": "Prasad Kirpekar"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.100.0"
  },
  "homepage": "https://github.com/prasadkirpekar/scaffold-vscode#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/prasadkirpekar/scaffold-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/prasadkirpekar/scaffold-vscode/issues"
  },
  "icon": "media/scaffold.png",
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "files": [
    "out/**",
    "media/scaffold.png",
    "media/scaffold.svg",
    "assets/**",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "scaffold",
    "project planning",
    "prd",
    "engineering plan",
    "knowledge base",
    "ready to code",
    "ai coding",
    "github copilot",
    "gemini",
    "claude",
    "requirements mapping"
  ],
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "scaffold",
          "title": "Scaffold",
          "icon": "media/scaffold.svg"
        }
      ]
    },
    "views": {
      "scaffold": [
        {
          "id": "scaffold.knowledgeBase",
          "name": "Knowledge Base"
        },
        {
          "id": "scaffold.prd",
          "name": "Product Requirement Document"
        },
        {
          "id": "scaffold.design",
          "name": "Design"
        },
        {
          "id": "scaffold.engineeringPlan",
          "name": "Engineering Plan"
        },
        {
          "id": "scaffold.readyToBuild",
          "name": "Ready to Code"
        },
        {
          "id": "scaffold.build",
          "name": "Code"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "scaffold.knowledgeBase",
        "contents": "Initialize Scaffold before using this workspace.\n[Initialize Workspace](command:scaffold.initializeWorkspace)",
        "when": "!scaffoldInitialized"
      },
      {
        "view": "scaffold.prd",
        "contents": "Initialize Scaffold before using this workspace.\n[Initialize Workspace](command:scaffold.initializeWorkspace)",
        "when": "!scaffoldInitialized"
      },
      {
        "view": "scaffold.design",
        "contents": "Initialize Scaffold before using this workspace.\n[Initialize Workspace](command:scaffold.initializeWorkspace)",
        "when": "!scaffoldInitialized"
      },
      {
        "view": "scaffold.engineeringPlan",
        "contents": "Initialize Scaffold before using this workspace.\n[Initialize Workspace](command:scaffold.initializeWorkspace)",
        "when": "!scaffoldInitialized"
      },
      {
        "view": "scaffold.readyToBuild",
        "contents": "Initialize Scaffold before using this workspace.\n[Initialize Workspace](command:scaffold.initializeWorkspace)",
        "when": "!scaffoldInitialized"
      },
      {
        "view": "scaffold.build",
        "contents": "Initialize Scaffold before using this workspace.\n[Initialize Workspace](command:scaffold.initializeWorkspace)",
        "when": "!scaffoldInitialized"
      }
    ],
    "commands": [
      {
        "command": "scaffold.initializeWorkspace",
        "title": "Initialize Workspace",
        "icon": "$(gear)"
      },
      {
        "command": "scaffold.approveSection",
        "title": "Approve Section",
        "icon": "$(pass-filled)"
      },
      {
        "command": "scaffold.approveFile",
        "title": "Approve File",
        "icon": "$(check)"
      },
      {
        "command": "scaffold.createFileInSection",
        "title": "New File",
        "icon": "$(new-file)"
      },
      {
        "command": "scaffold.createFolderInSection",
        "title": "New Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "scaffold.createKnowledgeBaseFile",
        "title": "New File",
        "icon": "$(new-file)"
      },
      {
        "command": "scaffold.createKnowledgeBaseFolder",
        "title": "New Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "scaffold.createPrdFile",
        "title": "New File",
        "icon": "$(new-file)"
      },
      {
        "command": "scaffold.createPrdFolder",
        "title": "New Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "scaffold.approvePrdSection",
        "title": "Approve Product Requirement Document",
        "icon": "$(pass-filled)"
      },
      {
        "command": "scaffold.createDesignFile",
        "title": "New File",
        "icon": "$(new-file)"
      },
      {
        "command": "scaffold.createDesignFolder",
        "title": "New Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "scaffold.approveDesignSection",
        "title": "Approve Design",
        "icon": "$(pass-filled)"
      },
      {
        "command": "scaffold.createEngineeringPlanFile",
        "title": "New File",
        "icon": "$(new-file)"
      },
      {
        "command": "scaffold.createEngineeringPlanFolder",
        "title": "New Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "scaffold.approveEngineeringPlanSection",
        "title": "Approve Engineering Plan",
        "icon": "$(pass-filled)"
      },
      {
        "command": "scaffold.approveReadyToBuildSection",
        "title": "Approve Ready to Code",
        "icon": "$(pass-filled)"
      },
      {
        "command": "scaffold.generateReadyToBuildPrompt",
        "title": "Generate Ready-to-Code Prompt",
        "icon": "$(sparkle)"
      },
      {
        "command": "scaffold.createBuildFile",
        "title": "New File",
        "icon": "$(new-file)"
      },
      {
        "command": "scaffold.createBuildFolder",
        "title": "New Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "scaffold.generateBuildPrompt",
        "title": "Generate Code Prompt",
        "icon": "$(rocket)"
      },
      {
        "command": "scaffold.openBuildFolderExternal",
        "title": "Open Code Folder Externally",
        "icon": "$(go-to-file)"
      },
      {
        "command": "scaffold.renameItem",
        "title": "Rename",
        "icon": "$(edit)"
      },
      {
        "command": "scaffold.deleteItem",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "scaffold.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "scaffold.createKnowledgeBaseFile",
          "when": "view == scaffold.knowledgeBase && scaffoldInitialized",
          "group": "navigation",
          "icon": "$(new-file)"
        },
        {
          "command": "scaffold.createKnowledgeBaseFolder",
          "when": "view == scaffold.knowledgeBase && scaffoldInitialized",
          "group": "navigation",
          "icon": "$(new-folder)"
        },
        {
          "command": "scaffold.createPrdFile",
          "when": "view == scaffold.prd && scaffoldInitialized",
          "group": "navigation",
          "icon": "$(new-file)"
        },
        {
          "command": "scaffold.createPrdFolder",
          "when": "view == scaffold.prd && scaffoldInitialized",
          "group": "navigation",
          "icon": "$(new-folder)"
        },
        {
          "command": "scaffold.approvePrdSection",
          "when": "view == scaffold.prd && scaffoldInitialized",
          "group": "navigation",
          "icon": "$(pass-filled)"
        },
        {
          "command": "scaffold.createDesignFile",
          "when": "view == scaffold.design && scaffoldInitialized",
          "group": "navigation",
          "icon": "$(new-file)"
        },
        {
          "command": "scaffold.createDesignFolder",
          "when": "view == scaffold.design && scaffoldInitialized",
          "group": "navigation",
          "icon": "$(new-folder)"
        },
        {
          "command": "scaffold.approveDesignSection",
          "when": "view == scaffold.design && scaffoldInitialized",
          "group": "navigation",
          "icon": "$(pass-filled)"
        },
        {
          "command": "scaffold.createEngineeringPlanFile",
          "when": "view == scaffold.engineeringPlan && scaffoldInitialized",
          "group": "navigation",
          "icon": "$(new-file)"
        },
        {
          "command": "scaffold.createEngineeringPlanFolder",
          "when": "view == scaffold.engineeringPlan && scaffoldInitialized",
          "group": "navigation",
          "icon": "$(new-folder)"
        },
        {
          "command": "scaffold.approveEngineeringPlanSection",
          "when": "view == scaffold.engineeringPlan && scaffoldInitialized",
          "group": "navigation",
          "icon": "$(pass-filled)"
        },
        {
          "command": "scaffold.generateReadyToBuildPrompt",
          "when": "view == scaffold.readyToBuild && scaffoldInitialized",
          "group": "navigation",
          "icon": "$(sparkle)"
        },
        {
          "command": "scaffold.approveReadyToBuildSection",
          "when": "view == scaffold.readyToBuild && scaffoldInitialized",
          "group": "navigation",
          "icon": "$(pass-filled)"
        },
        {
          "command": "scaffold.createBuildFile",
          "when": "view == scaffold.build && scaffoldInitialized",
          "group": "navigation",
          "icon": "$(new-file)"
        },
        {
          "command": "scaffold.createBuildFolder",
          "when": "view == scaffold.build && scaffoldInitialized",
          "group": "navigation",
          "icon": "$(new-folder)"
        },
        {
          "command": "scaffold.generateBuildPrompt",
          "when": "view == scaffold.build && scaffoldInitialized",
          "group": "navigation",
          "icon": "$(rocket)"
        },
        {
          "command": "scaffold.openBuildFolderExternal",
          "when": "view == scaffold.build && scaffoldInitialized",
          "group": "navigation",
          "icon": "$(go-to-file)"
        },
        {
          "command": "scaffold.refresh",
          "when": "view == scaffold.knowledgeBase || view == scaffold.prd || view == scaffold.design || view == scaffold.engineeringPlan || view == scaffold.readyToBuild || view == scaffold.build",
          "group": "navigation",
          "icon": "$(refresh)"
        }
      ],
      "view/item/context": [
        {
          "command": "scaffold.approveSection",
          "when": "viewItem == section.gate.pending"
        },
        {
          "command": "scaffold.createFileInSection",
          "when": "viewItem == section.folder"
        },
        {
          "command": "scaffold.createFolderInSection",
          "when": "viewItem == section.folder"
        },
        {
          "command": "scaffold.approveFile",
          "when": "viewItem == section.file.pending"
        },
        {
          "command": "scaffold.renameItem",
          "when": "viewItem =~ /^section\\.(file|folder)/",
          "group": "9_modification@1"
        },
        {
          "command": "scaffold.deleteItem",
          "when": "viewItem =~ /^section\\.(file|folder)/",
          "group": "9_modification@2"
        }
      ]
    },
    "configuration": {
      "title": "Scaffold",
      "properties": {
        "scaffold.gateMode": {
          "type": "string",
          "enum": [
            "strict",
            "flexible"
          ],
          "default": "strict",
          "description": "Gate progression mode. strict enforces sequential approvals; flexible allows manual overrides."
        },
        "scaffold.dataFolder": {
          "type": "string",
          "default": ".scaffold",
          "description": "Folder at workspace root used for Scaffold local data."
        },
        "scaffold.readyToBuildPromptTemplate": {
          "type": "string",
          "default": "You are generating Ready-to-Code implementation tasks for Scaffold.\n\nSource of truth (read in order):\n1) Knowledge Base index: {{knowledgeBaseIndexPath}}\n2) Product Requirement Document index: {{prdIndexPath}}\n3) Design index: {{designIndexPath}}\n4) Engineering Plan index: {{engineeringPlanIndexPath}}\n\nSection roots:\n- Knowledge Base: {{knowledgeBasePath}}\n- Product Requirement Document: {{prdPath}}\n- Design: {{designPath}}\n- Engineering Plan: {{engineeringPlanPath}}\n- Ready to Code: {{readyToBuildPath}}\n\nTask:\nGenerate executable implementation tasks and produce:\n- one master backlog file\n- multiple task files grouped by feature/epic\n- each task with id, title, description, dependencies, acceptance criteria, tests, estimate (S/M/L), and risk\n\nConstraints:\n- Do not invent features beyond source docs.\n- Add explicit Open Question tasks for ambiguities.\n- Keep tasks implementation-ready and testable.\n- Prefer incremental vertical slices.\n\nOutput:\n1) Proposed file tree under {{readyToBuildPath}}\n2) Full file contents\n3) Traceability table from tasks to source files",
          "markdownDescription": "Template used by **Generate Ready-to-Code Prompt**. Supported tokens: `{{knowledgeBasePath}}`, `{{prdPath}}`, `{{designPath}}`, `{{engineeringPlanPath}}`, `{{readyToBuildPath}}`, `{{buildPath}}`, `{{knowledgeBaseIndexPath}}`, `{{prdIndexPath}}`, `{{designIndexPath}}`, `{{engineeringPlanIndexPath}}`, `{{readyToBuildIndexPath}}`, `{{buildIndexPath}}`."
        },
        "scaffold.readyToBuildPromptOutput": {
          "type": "string",
          "enum": [
            "editor",
            "clipboard",
            "both"
          ],
          "default": "both",
          "description": "Where generated Ready-to-Code prompts are sent."
        },
        "scaffold.buildPromptTemplate": {
          "type": "string",
          "default": "You are starting implementation in the Code section for Scaffold.\n\nRead these planning sources first:\n1) Knowledge Base index: {{knowledgeBaseIndexPath}}\n2) Product Requirement Document index: {{prdIndexPath}}\n3) Design index: {{designIndexPath}}\n4) Engineering Plan index: {{engineeringPlanIndexPath}}\n5) Ready to Code index: {{readyToBuildIndexPath}}\n\nImplementation target:\n- Code root: {{buildPath}}\n- Keep all generated code under the project folder.\n- Respect existing file structure unless a change is required.\n\nTask:\n- Start coding the highest-priority tasks from Ready to Code.\n- Create/update files directly in {{buildPath}} and related project paths.\n- Keep changes small and incremental.\n- Include tests where appropriate.\n\nOutput:\n1) File-by-file change plan\n2) Exact code edits\n3) Validation steps and any open questions",
          "markdownDescription": "Template used by **Generate Code Prompt**. Supported tokens: `{{knowledgeBasePath}}`, `{{prdPath}}`, `{{designPath}}`, `{{engineeringPlanPath}}`, `{{readyToBuildPath}}`, `{{buildPath}}`, `{{knowledgeBaseIndexPath}}`, `{{prdIndexPath}}`, `{{designIndexPath}}`, `{{engineeringPlanIndexPath}}`, `{{readyToBuildIndexPath}}`, `{{buildIndexPath}}`."
        },
        "scaffold.buildPromptOutput": {
          "type": "string",
          "enum": [
            "editor",
            "clipboard",
            "both"
          ],
          "default": "both",
          "description": "Where generated Code prompts are sent."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/vscode": "^1.100.0",
    "typescript": "^5.8.3"
  }
}
